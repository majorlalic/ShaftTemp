<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csg.dgri.szsiom.sysmanage.model.MonitorVO">

    <select id="findActiveByDeviceId" parameterType="map" resultType="com.csg.dgri.szsiom.sysmanage.model.MonitorVO">
        <![CDATA[
        select * from ODS_DWEQ_DM_MONITOR_D where device_id = #{deviceId} and (deleted is null or deleted = 0)
        ]]>
    </select>

    <select id="findActiveByDeviceIds" parameterType="map" resultType="com.csg.dgri.szsiom.sysmanage.model.MonitorVO">
        select * from ODS_DWEQ_DM_MONITOR_D
        where (deleted is null or deleted = 0)
          and device_id in
        <foreach collection="deviceIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findActiveById" parameterType="map" resultType="com.csg.dgri.szsiom.sysmanage.model.MonitorVO">
        <![CDATA[
        select * from ODS_DWEQ_DM_MONITOR_D where id = #{id} and (deleted is null or deleted = 0)
        ]]>
    </select>

    <select id="findAllActive" parameterType="map" resultType="com.csg.dgri.szsiom.sysmanage.model.MonitorVO">
        <![CDATA[
        select * from ODS_DWEQ_DM_MONITOR_D where (deleted is null or deleted = 0)
        ]]>
    </select>

</mapper>
